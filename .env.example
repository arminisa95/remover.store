# Datenbank (Vercel Postgres / Neon)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL=https://remover.store
NEXTAUTH_SECRET=dein-secret-hier  # generieren mit: openssl rand -base64 32

